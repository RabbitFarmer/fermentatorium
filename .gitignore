# =============================================================================
# Fermentatorium .gitignore
# =============================================================================
# This file protects personal data, API credentials, and runtime files from
# being accidentally committed and pushed to GitHub.  Each section explains
# exactly what is protected and why.
# =============================================================================


# -----------------------------------------------------------------------------
# CONFIG FILES — credentials, API keys, and external logging URLs
# -----------------------------------------------------------------------------
# The live config/*.json files contain sensitive personal data and must NEVER
# be committed.  Specifically:
#
#   config/system_config.json
#     - brewery_name, brewer_name (personal identity)
#     - pushover_user_key, pushover_api_token (Pushover push-notification creds)
#     - smtp_password, smtp_user, smtp_from (email alert credentials)
#     - ntfy_url (ntfy notification URL, may contain private topic)
#     - kasa_plug_ip_* (local network device addresses)
#     - external_url_0, external_url_1, external_url_2 — EXTERNAL LOGGING URLS
#       These embed account-specific API keys directly in the URL, e.g.:
#         Brewer's Friend:  https://log.brewersfriend.com/stream/YOUR_API_KEY
#         BrewFather:       http://log.brewfather.net/stream?id=YOUR_STREAM_ID
#       Exposing these gives anyone full write access to your brewing account.
#
#   config/tilt_config.json
#     - per-tilt "external_url" field (same embedded-API-key risk as above)
#     - active beer/batch names (personal data)
#
#   config/tilt_table.json, config/temp_control_config.json
#     - calibration and temperature-control runtime state
#
# The *.json.template files (blank placeholders with no real values) are the
# ones that belong in the repo and ARE tracked — this rule keeps them safe.
config/*.json
!config/*.json.template


# -----------------------------------------------------------------------------
# RUNTIME DATA DIRECTORIES — fermentation logs and batch history
# -----------------------------------------------------------------------------
# These directories are created at runtime and contain personal brewing data
# (gravity/temperature readings, batch names, dates, notes).  They can grow
# large and have no place in version control.
logs/
batches/
export/
temp_control/


# -----------------------------------------------------------------------------
# LOG, DATABASE, AND BACKUP FILES
# -----------------------------------------------------------------------------
*.log
*.db
*.sqlite
*.sqlite3
*.bak


# -----------------------------------------------------------------------------
# PYTHON ARTIFACTS
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
dist/
build/


# -----------------------------------------------------------------------------
# VIRTUAL ENVIRONMENTS
# -----------------------------------------------------------------------------
# Never commit the venv — it is large, platform-specific, and regenerated by
# `pip install -r requirements.txt`.
venv/
.venv/
env/


# -----------------------------------------------------------------------------
# BREWER'S FRIEND / BREWFATHER DATA EXPORT FILES
# -----------------------------------------------------------------------------
# JSON data files downloaded from Brewer's Friend or BrewFather for import
# into the app often land in utils/ or the repo root.  They may contain
# recipe details and personal brew history.  Keep downloaded data files
# outside the repo directory; if you must stage them temporarily, store them
# in /tmp instead.
utils/*.json


# -----------------------------------------------------------------------------
# OS ARTIFACTS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini


# -----------------------------------------------------------------------------
# EDITOR / IDE ARTIFACTS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# TOOL CACHES
# -----------------------------------------------------------------------------
.cache/
.pytest_cache/
.mypy_cache/
